# ──────────────────────────────────────────────────────────
# secrets.toml — Multi-profile configuration example
#
# Usage:
#   python app.py --llm <llm_profile_name> --database <db_profile_name>
#
# Example:
#   python app.py --llm lmstudio --database snowflake
#   python app.py --llm gemini --database postgres_local
# ──────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════
# LLM Configurations
# ══════════════════════════════════════════════════════════

# LM Studio (Local LLM)
[llm.local-llm]
provider = "local-llm"
model = "openai/gpt-oss-20b"
#model = "openai/gpt-oss-120b"
#base_url = "http://localhost:1234/v1"
base_url = "http://host.docker.internal:1234/v1"
api_key = "test-key"

# OpenAI API (GPT-4)
[llm.openai]
provider = "local-llm"
model = "gpt-4"
base_url = "https://api.openai.com/v1"
api_key = "sk-YOUR_OPENAI_API_KEY"

# Mistral (via local-llm)
[llm.mistral]
provider = "local-llm"
model = "mistral-medium"
base_url = "https://api.mistral.ai/v1"
api_key = "YOUR_MISTRAL_API_KEY"

# Google Gemini
[llm.gemini]
provider = "gemini"
model = "gemini-2.0-flash"
api_key = "YOUR_GEMINI_API_KEY"

# Anthropic Claude
[llm.anthropic]
provider = "anthropic"
model = "claude-3-5-sonnet-20241022"
api_key = "sk-ant-YOUR_ANTHROPIC_API_KEY"

# Ollama (local)
[llm.ollama]
provider = "ollama"
model = "llama2"
base_url = "http://localhost:11434"

# ══════════════════════════════════════════════════════════
# Database Configurations
# ══════════════════════════════════════════════════════════

# Snowflake
[database.snowflake]
type = "snowflake"
account = "ci-test"
user = "ci@test.com"
private_key_path = ".rsa/rsa_key.p8"
role = "CI_ROLE"
warehouse = "CI_WH"
database = "CI_DB"
schema = "CI_SCHEMA"

# PostgreSQL (local)
[database.postgres_local]
type = "postgresql"
host = "localhost"
port = 5432
database = "mydb"
user = "myuser"
password = "mypassword"

# MySQL
[database.mysql_prod]
type = "mysql"
host = "mysql.example.com"
port = 3306
database = "prod_db"
user = "admin"
password = "secret"

# Oracle
[database.oracle_dev]
type = "oracle"
user = "ora_user"
password = "ora_pass"
dsn = "localhost:1521/XEPDB1"

# ══════════════════════════════════════════════════════════
# Optional Training Configuration
# ══════════════════════════════════════════════════════════

[training]
# Optional cap for Snowflake schema training in normal mode (0 = no limit)
snowflake_table_limit = 0
